import { Page } from '@playwright/test';
import { PdpLocators } from '../../locators/contracts/PDPLocators';
import { getPDPLocators } from '../../locators/registry/PDPRegistry';

/**
 * Base PDP page object. Holds the Shared/Override method BODIES once; resolves
 * selectors per brand through the registry. Brand seams extend this.
 */
export class BasePDPPage {
  protected readonly page: Page;
  protected readonly L: PdpLocators;

  constructor(page: Page, brandId: string) {
    this.page = page;
    this.L = getPDPLocators(brandId);
  }

  async getProductName(): Promise<string> {
    return (await this.L.productName(this.page).first().textContent())?.trim() ?? '';
  }

  /**
   * Select the first available size and VERIFY it registered.
   *
   * Robust version: scrolls the swatch into view, clicks it, then confirms the
   * selection actually took (aria-checked / selected class). Throws a clear error
   * instead of silently swallowing — a missed size is the root cause of the
   * "Add to Bag stays disabled" failure, so we surface it loudly.
   */
  async selectFirstAvailableSize(): Promise<void> {
    const sizes = this.L.sizeOption(this.page);
    const count = await sizes.count();
    if (count === 0) {
      // Product may be single-size / no swatches — not necessarily an error.
      return;
    }

    // Try each visible size until one selects successfully (skips out-of-stock).
    for (let i = 0; i < count; i++) {
      const swatch = sizes.nth(i);
      if (!(await swatch.isVisible().catch(() => false))) continue;

      await swatch.scrollIntoViewIfNeeded().catch(() => {});
      await swatch.click().catch(() => {});

      // Give the PDP a moment to mark selection + enable Add to Bag.
      const selected = await this.page
        .locator('a.swatchanchor[aria-checked="true"], a.swatchanchor.selected, .swatchanchor.selected')
        .count()
        .catch(() => 0);

      // Also accept "add to cart is now enabled" as proof the size took.
      const enabled = await this.page
        .locator('button#add-to-cart:not(.add-to-cart-disabled)')
        .first()
        .isVisible()
        .catch(() => false);

      if (selected > 0 || enabled) return;
    }

    throw new Error(
      `Tried ${count} size swatch(es) but none registered as selected ` +
      `(Add to Bag never enabled). Check the size selector or that any size is in stock.`
    );
  }

  /**
   * Click Add to Bag. Scrolls into view first (the main button can be below the
   * fold). Targets the enabled, non-sticky button per the brand's selector.
   */
  async addToCart(): Promise<void> {
    const btn = this.L.addToCart(this.page).first();
    await btn.scrollIntoViewIfNeeded().catch(() => {});
    await btn.click();
  }

  async goToCart(): Promise<void> {
    await this.L.goToCartLink(this.page).first().click();
  }
}
